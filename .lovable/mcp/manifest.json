{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://mbxlvsftyifovbkpsvyw.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "contentforge-mcp",
      "version": "0.1.0",
      "title": "ContentForge"
    },
    "tools": [
      {
        "name": "list_calendars",
        "title": "List content calendars",
        "description": "List the signed-in user's saved ContentForge content calendars, newest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "limit": {
              "description": "Max calendars to return (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "get_calendar",
        "title": "Get a content calendar",
        "description": "Fetch one saved ContentForge calendar (including all posts) by its ID for the signed-in user.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
              "description": "The calendar's UUID."
            }
          },
          "required": [
            "id"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_scheduled_posts",
        "title": "List scheduled posts",
        "description": "List the signed-in user's upcoming scheduled ContentForge posts, ordered by scheduled_at.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "status": {
              "description": "Filter by status.",
              "type": "string",
              "enum": [
                "scheduled",
                "published",
                "failed",
                "draft"
              ]
            },
            "limit": {
              "description": "Max posts to return (default 25).",
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          }
        },
        "outputSchema": null
      },
      {
        "name": "extract_ideas",
        "title": "Extract post ideas from source material",
        "description": "Analyze pasted long-form source material (an article, transcript, or notes) and extract distinct, high-potential social post ideas mapped to proven engagement formats, for the signed-in user. Calls the same `extract-ideas` pipeline the app UI uses, so per-user rate limits and generation quota apply.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "source": {
              "type": "string",
              "minLength": 200,
              "maxLength": 20000,
              "description": "The long-form source text to extract ideas from."
            },
            "count": {
              "description": "How many distinct ideas to extract (default 5).",
              "type": "integer",
              "minimum": 3,
              "maximum": 10
            },
            "platform": {
              "description": "Target platform for the ideas, e.g. LinkedIn, X, Instagram (default LinkedIn).",
              "type": "string"
            }
          },
          "required": [
            "source"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "repurpose_post",
        "title": "Repurpose a post for another platform",
        "description": "Rewrite an existing post for a different target platform (e.g. take a LinkedIn post and rewrite it for X or Instagram), preserving the strategic angle. Calls the same `repurpose-post` pipeline the app UI uses, so per-user rate limits and generation quota apply.",
        "annotations": {
          "readOnlyHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "post": {
              "type": "object",
              "properties": {
                "title": {
                  "type": "string"
                },
                "hook": {
                  "type": "string"
                },
                "body": {
                  "type": "string"
                },
                "cta": {
                  "type": "string"
                },
                "hashtags": {
                  "type": "string"
                },
                "topic": {
                  "type": "string"
                },
                "format": {
                  "type": "string"
                },
                "dow": {
                  "type": "string"
                }
              },
              "additionalProperties": {},
              "description": "The source post to repurpose. Provide at minimum a hook or body."
            },
            "targetPlatform": {
              "type": "string",
              "minLength": 1,
              "description": "Platform to rewrite the post for, e.g. X, Instagram, Facebook, Newsletter."
            },
            "platform": {
              "description": "The post's current/source platform (default LinkedIn).",
              "type": "string"
            }
          },
          "required": [
            "post",
            "targetPlatform"
          ]
        },
        "outputSchema": null
      },
      {
        "name": "list_trends",
        "title": "List trending topics",
        "description": "List recent trending keywords from the `trends` table populated by the trends-ingest pipeline (supabase/functions/trends-ingest), ordered by volume. This is shared, non-personal data readable by any signed-in user — the same table src/components/InspirationBank.tsx reads.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "category": {
              "description": "Filter to trends whose category matches this text (case-insensitive substring match, e.g. an industry name).",
              "type": "string"
            },
            "limit": {
              "description": "Max trends to return (default 20).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
