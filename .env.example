# Example environment variables for the Social Spark frontend
# Copy to .env and fill in with your Supabase project's values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# Optional: error tracking
VITE_SENTRY_DSN=

# Razorpay — public Key ID only (safe for the browser). NEVER put the key secret here.
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
# RAZORPAY_KEY_ID and RAZORPAY_KEY_SECRET are set as Supabase Edge Function secrets, not in this file:
#   supabase secrets set RAZORPAY_KEY_ID=... RAZORPAY_KEY_SECRET=...
