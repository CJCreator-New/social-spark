# Example environment variables for trends ingestion
# Copy to .env or set in your deployment environment
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...service_role_key
SUPABASE_DB_CONN=postgres://user:pass@db.host:5432/postgres

# API keys
X_BEARER_TOKEN=YOUR_X_BEARER_TOKEN
NEWSAPI_KEY=YOUR_NEWSAPI_KEY

# Monitoring
SENTRY_DSN=YOUR_SENTRY_DSN
PUSHGATEWAY_URL=https://pushgateway.example.com/metrics

# Supabase CLI project ref
SUPABASE_PROJECT_REF=your-project-ref
